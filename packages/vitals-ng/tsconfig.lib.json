{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "sourceMap": true,
    "paths": {
      "@myhealth/design-kit": ["./packages/design-kit"]
    },
    "types": []
  },
  "include": [
    "**/*.ts",
    "divider/**/*.ts",
    "spinner/**/*.ts",
    "spinner/divider/**/*.ts",
    "skeleton/**/*.ts",
    "skeleton/divider/**/*.ts",
    "skeleton/spinner/**/*.ts",
    "skeleton/spinner/divider/**/*.ts",
    "icon/**/*.ts",
    "icon/divider/**/*.ts",
    "icon/spinner/**/*.ts",
    "icon/spinner/divider/**/*.ts",
    "icon/skeleton/**/*.ts",
    "icon/skeleton/divider/**/*.ts",
    "icon/skeleton/spinner/**/*.ts",
    "icon/skeleton/spinner/divider/**/*.ts",
    "icon-button/**/*.ts",
    "icon-button/divider/**/*.ts",
    "icon-button/spinner/**/*.ts",
    "icon-button/spinner/divider/**/*.ts",
    "icon-button/skeleton/**/*.ts",
    "icon-button/skeleton/divider/**/*.ts",
    "icon-button/skeleton/spinner/**/*.ts",
    "icon-button/skeleton/spinner/divider/**/*.ts",
    "icon-button/icon/**/*.ts",
    "icon-button/icon/divider/**/*.ts",
    "icon-button/icon/spinner/**/*.ts",
    "icon-button/icon/spinner/divider/**/*.ts",
    "icon-button/icon/skeleton/**/*.ts",
    "icon-button/icon/skeleton/divider/**/*.ts",
    "icon-button/icon/skeleton/spinner/**/*.ts",
    "icon-button/icon/skeleton/spinner/divider/**/*.ts"
  ],
  "exclude": [
    "**/*.spec.ts",
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/test-setup.ts",
    "divider/**/*.spec.ts",
    "spinner/**/*.spec.ts",
    "spinner/divider/**/*.spec.ts",
    "skeleton/**/*.spec.ts",
    "skeleton/divider/**/*.spec.ts",
    "skeleton/spinner/**/*.spec.ts",
    "skeleton/spinner/divider/**/*.spec.ts",
    "icon/**/*.spec.ts",
    "icon/divider/**/*.spec.ts",
    "icon/spinner/**/*.spec.ts",
    "icon/spinner/divider/**/*.spec.ts",
    "icon/skeleton/**/*.spec.ts",
    "icon/skeleton/divider/**/*.spec.ts",
    "icon/skeleton/spinner/**/*.spec.ts",
    "icon/skeleton/spinner/divider/**/*.spec.ts",
    "icon-button/**/*.spec.ts",
    "icon-button/divider/**/*.spec.ts",
    "icon-button/spinner/**/*.spec.ts",
    "icon-button/spinner/divider/**/*.spec.ts",
    "icon-button/skeleton/**/*.spec.ts",
    "icon-button/skeleton/divider/**/*.spec.ts",
    "icon-button/skeleton/spinner/**/*.spec.ts",
    "icon-button/skeleton/spinner/divider/**/*.spec.ts",
    "icon-button/icon/**/*.spec.ts",
    "icon-button/icon/divider/**/*.spec.ts",
    "icon-button/icon/spinner/**/*.spec.ts",
    "icon-button/icon/spinner/divider/**/*.spec.ts",
    "icon-button/icon/skeleton/**/*.spec.ts",
    "icon-button/icon/skeleton/divider/**/*.spec.ts",
    "icon-button/icon/skeleton/spinner/**/*.spec.ts",
    "icon-button/icon/skeleton/spinner/divider/**/*.spec.ts"
  ],
  "references": [
    {
      "path": "../design-kit/tsconfig.lib.json"
    }
  ]
}
